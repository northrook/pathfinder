{
  "name": "northrook/pathfinder",
  "description": "A PHP library to help find paths and directories at runtime using predefined key-value pairs",
  "type": "library",
  "license": "BSD-3-Clause",
  "authors": [
    {
      "name": "Martin",
      "email": "mn@northrook.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Northrook\\Core\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Northrook\\Tests\\": "tests"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": ">=8.4",
    "ext-fileinfo": "*",
    "northrook/core": "dev-main",
    "northrook/core-contracts": "dev-main"
  },
  "require-dev": {
    "northrook/php-cs": "dev-main",
    "phpstan/phpstan": "^2.2",
    "phpstan/extension-installer": "^1.4",
    "phpunit/phpunit": "^11.5"
  },
  "scripts": {
    "phpstan": "vendor/bin/phpstan analyse",
    "test": "phpunit"
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  }
}
